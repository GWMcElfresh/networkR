\name{networkR-package}
\alias{networkR-package}
\alias{networkR}
\title{networkR: Flexible Bayesian Network Pipelines}
\description{
The \pkg{networkR} package provides configurable Bayesian network analysis
workflows for factorial and repeated-measures studies. The current scaffold
supports panel ingestion, derived variable handling, predictive mean matching
imputation, discretization, blacklist construction, structure learning,
structure comparison, and ggraph-based visualization.
}
\keyword{package}